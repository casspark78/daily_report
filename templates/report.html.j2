<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daily Report · {{ date_str }}</title>
<style>
  :root {
    color-scheme: light dark;
    --bg: #f7f7f5;
    --card: #ffffff;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --accent: #2563eb;
    --border: #e5e5e0;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #15161a;
      --card: #1e2026;
      --text: #eaeaea;
      --muted: #9a9a9a;
      --accent: #6ea8fe;
      --border: #2c2e35;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
    line-height: 1.55;
  }
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 20px 80px;
  }
  header.page-head {
    margin-bottom: 32px;
  }
  header.page-head h1 {
    font-size: 1.5rem;
    margin: 0 0 6px;
  }
  header.page-head .meta {
    color: var(--muted);
    font-size: 0.9rem;
  }
  nav.toc {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 20px 0 0;
  }
  nav.toc a {
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 999px;
  }
  section.topic {
    margin-top: 40px;
    scroll-margin-top: 16px;
  }
  section.topic h2 {
    font-size: 1.15rem;
    border-bottom: 2px solid var(--border);
    padding-bottom: 8px;
    margin-bottom: 16px;
  }
  article.item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 12px;
  }
  article.item h3 {
    margin: 0 0 6px;
    font-size: 1rem;
  }
  article.item h3 a {
    color: var(--text);
    text-decoration: none;
  }
  article.item h3 a:hover {
    color: var(--accent);
  }
  article.item p.summary {
    margin: 0 0 8px;
    color: var(--text);
  }
  article.item .source {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .empty {
    color: var(--muted);
    font-size: 0.9rem;
    font-style: italic;
  }
  footer {
    margin-top: 48px;
    color: var(--muted);
    font-size: 0.8rem;
    text-align: center;
  }
</style>
</head>
<body>
<main>
  <header class="page-head">
    <h1>☕ Daily Report</h1>
    <div class="meta">{{ date_str }} · 총 {{ total_count }}건 · 약 {{ read_minutes }}분 소요</div>
    <nav class="toc">
      {% for topic in topics %}
      <a href="#{{ topic.id }}">{{ topic.title }}</a>
      {% endfor %}
    </nav>
  </header>

  {% for topic in topics %}
  <section class="topic" id="{{ topic.id }}">
    <h2>{{ topic.title }}</h2>
    {% if topic.articles %}
      {% for a in topic.articles %}
      <article class="item">
        <h3><a href="{{ a.link }}" target="_blank" rel="noopener">{{ a.title }}</a></h3>
        <p class="summary">{{ a.summary_ko }}</p>
        <div class="source">{{ a.source }}</div>
      </article>
      {% endfor %}
    {% else %}
      <p class="empty">오늘은 새로운 소식이 없습니다.</p>
    {% endif %}
  </section>
  {% endfor %}

  <footer>Generated automatically · {{ generated_at }}</footer>
</main>
</body>
</html>
